<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gym Camera Machine App UI</title>
<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #0f0f0f;
    color: white;
}
.container {
    display: flex;
    height: 100vh;
}
.sidebar {
    width: 250px;
    background: #1a1a1a;
    padding: 20px;
    box-shadow: 2px 0 10px rgba(0,0,0,0.5);
}
.sidebar h2 {
    color: #00ff99;
}
.sidebar ul {
    list-style: none;
    padding: 0;
}
.sidebar ul li {
    padding: 12px;
    margin: 10px 0;
    background: #222;
    border-radius: 10px;
    cursor: pointer;
    transition: 0.3s;
}
.sidebar ul li:hover {
    background: #00ff99;
    color: black;
}
.main {
    flex: 1;
    display: flex;
    flex-direction: column;
}
.topbar {
    background: #111;
    padding: 15px 25px;
    font-size: 24px;
    font-weight: bold;
    border-bottom: 1px solid #222;
}
.content {
    display: flex;
    flex: 1;
    padding: 20px;
    gap: 20px;
}
.camera-box, .machine-box {
    flex: 1;
    background: #1a1a1a;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 0 15px rgba(0,255,153,0.2);
}
.camera-screen {
    background: black;
    height: 300px;
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #555;
    font-size: 20px;
}
.machine-stats {
    margin-top: 20px;
}
.stat {
    background: #222;
    padding: 15px;
    border-radius: 12px;
    margin-bottom: 10px;
}
button {
    background: #00ff99;
    color: black;
    border: none;
    padding: 12px 20px;
    border-radius: 10px;
    font-weight: bold;
    cursor: pointer;
    margin-top: 15px;
}
button:hover {
    opacity: 0.8;
}
</style>
</head>
<body>

<div class="container">
    
    <div class="sidebar">
        <h2>GYM AI</h2>
        <ul>
            <li>Dashboard</li>
            <li>Live Camera</li>
            <li>Machines</li>
            <li>Workout Plan</li>
            <li>Analytics</li>
        </ul>
    </div>

    <div class="main">
        <div class="topbar">Smart Gym Monitoring System</div>

        <div class="content">
            
            <div class="camera-box">
                <h3>Live Camera</h3>
                <div class="camera-screen">
                    Camera Feed
                </div>
                <button>Start Camera</button>
            </div>

            <div class="machine-box">
                <h3>Machine Status</h3>
                <div class="machine-stats">
                    <div class="stat">Treadmill: Active</div>
                    <div class="stat">Bench Press: Available</div>
                    <div class="stat">Bike: In Use</div>
                    <div class="stat">Calories Burned Today: 1240</div>
                </div>
                <button>Sync Machines</button>
            </div>

        </div>
    </div>

</div>

</body>
</html>
